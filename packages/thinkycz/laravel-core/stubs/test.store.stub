<?php

declare(strict_types=1);

use App\Http\Controllers\Api\{{ model }}\{{ model }}StoreController;
use {{ namespacedModel }};
use App\Models\User;
use Database\Factories\{{ model }}Factory;
use Database\Factories\UserFactory;
use Thinkycz\LaravelCore\Support\Resolver;

test('store {{ table }}', function (): void {
    $auth = UserFactory::new()->createOne();
    expect($auth)->toBeInstanceOf(User::class);

    $model = {{ model }}Factory::new()
        ->for($auth)
        ->makeOne();
    expect($model)->toBeInstanceOf({{ model }}::class);

    $data = [
        'title' => $model->getTitle(),
    ];

    $response = $this->be($auth)->post(Resolver::resolveUrlGenerator()->action({{ model }}StoreController::class), $data);

    $response->assertOk();
});
